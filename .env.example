# AmiVoice Cloud Platform のマイページで取得した APPKEY
AMIVOICE_APP_KEY=

# 単語の登録先・認識で使うプロファイル ID
# マイページの辞書を使う場合は、接続情報のサービスIDの先頭に半角コロンを付けた値（例: :xxxxxxxx）
# 独自のプロファイルを使う場合は半角英数・- ・_ で任意の名前（例: my-words）
AMIVOICE_PROFILE_ID=

# Anthropic API キー（校正案・単語候補の生成に使用）
ANTHROPIC_API_KEY=

# 任意: 校正に使うモデル（既定: claude-sonnet-4-6）
# PROOFREAD_MODEL=claude-sonnet-4-6
